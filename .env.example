DATABASE_URL="postgresql://user:password@localhost:5432/booking_corsi?schema=public"

NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="genera-con-openssl-rand-base64-32"

SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="tua@email.com"
SMTP_PASS="tua-app-password"
SMTP_FROM="noreply@tuodominio.it"

# Opzionale: Google OAuth
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

APP_URL="http://localhost:3000"
APP_NAME="Gestione Corsi"

# Cloudflare Turnstile CAPTCHA (opzionale — se non impostato il CAPTCHA è disabilitato)
# Ottieni le chiavi su: https://dash.cloudflare.com → Turnstile
# NEXT_PUBLIC_TURNSTILE_SITE_KEY="0x..."
# TURNSTILE_SECRET_KEY="0x..."

# Stripe (configurabile anche da pannello admin)
# STRIPE_SECRET_KEY="sk_live_..."
# STRIPE_PUBLISHABLE_KEY="pk_live_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."

# PayPal (configurabile anche da pannello admin)
# PAYPAL_CLIENT_ID="..."
# PAYPAL_CLIENT_SECRET="..."
# PAYPAL_MODE="sandbox"
