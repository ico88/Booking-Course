FLASK_ENV=development
SECRET_KEY=cambia-con-openssl-rand-base64-32
DEBUG=True

# SQLite (default, nessuna installazione richiesta)
DATABASE_URL=sqlite:///booking.db

# PostgreSQL (opzionale, per produzione)
# DATABASE_URL=postgresql://booking_user:password@localhost:5432/booking_corsi

APP_URL=http://localhost:5000
APP_NAME=Gestione Corsi
SESSION_COOKIE_SECURE=false

# SMTP (opzionale in sviluppo)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tua@email.com
SMTP_PASS=app-password

# Opzionali
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_PUBLISHABLE_KEY=pk_live_...
# PAYPAL_CLIENT_ID=...
# PAYPAL_CLIENT_SECRET=...
# PAYPAL_MODE=sandbox
# TURNSTILE_SITE_KEY=...
